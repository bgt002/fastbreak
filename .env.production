# Loaded by Expo when running `expo export --platform web` (i.e. `npm run
# build:web`) so production bundles point at the deployed Fly.io backend.
# Local dev still uses `.env` (gitignored) which points at the LAN IP.
# Both files are read; .env.production wins for production builds.
EXPO_PUBLIC_NBA_API_BASE_URL=https://backend-gentle-harborbird-7576.fly.dev
